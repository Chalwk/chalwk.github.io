{
  "name": "{{ page.title }}",
  "short_name": "{{ page.short_name | default: page.title }}",
  "description": "{{ page.description | default: site.description }}",
  "start_url": "{{ page.start_url | default: './' }}",
  "scope": "{{ page.scope | default: './' }}",
  "display": "{{ page.display | default: 'standalone' }}",
  "background_color": "{{ page.background_color | default: '#4a86e8' }}",
  "theme_color": "{{ page.theme_color | default: '#4a86e8' }}",
  "orientation": "{{ page.orientation | default: 'any' }}",
  "icons": [
    {% assign icons = page.icons | default: site.default_icons %}
    {% for icon in icons %}
    {
      "src": "{{ icon.src }}",
      "sizes": "{{ icon.sizes }}",
      "type": "{{ icon.type }}",
      "purpose": "{{ icon.purpose }}"
    }{% unless forloop.last %},{% endunless %}
    {% endfor %}
  ],
  "categories": {{ page.categories | default: site.default_categories | jsonify }},
  "lang": "{{ page.lang | default: 'en' }}"
}